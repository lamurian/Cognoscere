# Blacklist all Obsidian config files
.obsidian/*

# Blacklist vim swap files
*swp

# Whitelist several configuration files that needs to be synced
!.obsidian/app.json
!.obsidian/command-palette.json
!.obsidian/hotkeys.json
!.obsidian/*plugins.json

# Blacklist node modules
**/node_modules/**

# DuckDB knowledge index (auto-created and populated from .md files)
notes.duckdb
notes.duckdb.wal

# Sensitive environment variables
*.env*
!.env.example
.duckdb_tmp
