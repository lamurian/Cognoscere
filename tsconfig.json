{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "declaration": false,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true
  },
  "include": [
    ".pi/extensions/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
